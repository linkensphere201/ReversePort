{
  "name": "reverse-proxy-extension",
  "displayName": "Reverse Proxy",
  "description": "Start and stop an SSH reverse proxy from VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:reverseProxy.start",
    "onCommand:reverseProxy.stop",
    "onCommand:reverseProxy.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reverseProxy.start",
        "title": "Reverse Proxy: Start"
      },
      {
        "command": "reverseProxy.stop",
        "title": "Reverse Proxy: Stop"
      },
      {
        "command": "reverseProxy.openPanel",
        "title": "Reverse Proxy: Open Panel"
      }
    ],
    "configuration": {
      "title": "Reverse Proxy",
      "properties": {
        "reverseProxy.sshPath": {
          "type": "string",
          "default": "ssh",
          "description": "Path to ssh executable."
        },
        "reverseProxy.configFile": {
          "type": "string",
          "default": "reverse-proxy.config.json",
          "description": "Path to reverse proxy config JSON file. Relative path resolves from workspace root."
        },
        "reverseProxy.connectionReadyDelayMs": {
          "type": "number",
          "default": 1200,
          "minimum": 100,
          "description": "Delay in milliseconds before considering the tunnel connected."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile-tests": "tsc -p ./tsconfig.test.json",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "@types/mocha": "^10.0.7",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.7.3",
    "typescript": "^5.4.5"
  }
}
